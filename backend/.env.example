# Backend env (used when running outside docker). In docker-compose these are
# injected automatically. Copy to .env to override.
SECRET_KEY=change-me-in-production-please-use-a-long-random-string
DATABASE_URL=mysql+pymysql://yumi:yumipass@localhost:3306/yumi
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
PUBLIC_BASE_URL=http://localhost:5173
