# Copy to .env to override docker-compose defaults (optional — defaults work out of the box).
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=yumi
MYSQL_USER=yumi
MYSQL_PASSWORD=yumipass
MYSQL_PORT=3306

BACKEND_PORT=8000
FRONTEND_PORT=5173
SECRET_KEY=change-me-in-production-please-use-a-long-random-string
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
PUBLIC_BASE_URL=http://localhost:5173
